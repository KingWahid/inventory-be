APP_ENV=development
# HTTP port for inventory API (notification uses 8081 in docker-compose)
APP_PORT=8080
# Single line for lib/pq and goose (local: localhost; docker compose: host=postgres)
DB_DSN=host=localhost user=inventory password=inventory_password dbname=inventory sslmode=disable
REDIS_ADDR=localhost:6379
JWT_SECRET=change-me-in-production
LOG_LEVEL=info
# Browser/client calls Kong; matches docker-compose kong proxy port
KONG_PROXY_URL=http://localhost:8000
SSE_ENABLED=true
