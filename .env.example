APP_ENV=development
# HTTP port for inventory API (notification uses 8081 in docker-compose)
APP_PORT=8080
# Single line for lib/pq and goose (local: localhost; docker compose: host=postgres)
DB_DSN=host=localhost user=inventory password=inventory_password dbname=inventory sslmode=disable
REDIS_ADDR=localhost:6379
# Shared HS256 secret (dev). For production prefer JWT_ACCESS_SECRET + JWT_REFRESH_SECRET.
JWT_SECRET=change-me-in-production
# Optional: split keys so refresh tokens are never verifiable with the access key only.
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# Optional issuer/audience claims (both services must use the same values).
# JWT_ISSUER=inventory-api
# JWT_AUDIENCE=inventory-clients
# Must match authentication-service if inventory verifies login-issued JWTs.
# Access JWT lifetime (seconds); 86400 = 24h
JWT_ACCESS_TTL_SECONDS=86400
JWT_REFRESH_TTL_SECONDS=604800
LOG_LEVEL=info
# Browser/client calls Kong; matches docker-compose kong proxy port
KONG_PROXY_URL=http://localhost:8000
SSE_ENABLED=true
